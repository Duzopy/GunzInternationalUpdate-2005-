<!-- 프레임 생성 : 캐릭터 삭제 확인 -->
	<FRAME item="CS_ConfirmDeleteChar">
		<FRAMELOOK>DefaultFrameLook</FRAMELOOK>
		<BOUNDS>
			<X>0</X>
			<Y>0</Y>
			<W>300</W>
			<H>181</H>
		</BOUNDS>
		<ALIGN>
			<HALIGN>center</HALIGN>
			<VALIGN>center</VALIGN>
		</ALIGN>
		<RESIZABLE>false</RESIZABLE>
		<MOVABLE>false</MOVABLE>
		<TEXT>Delete a character</TEXT>
		<VISIBLE>FALSE</VISIBLE>
	</FRAME>
	
	<!-- Label : 캐릭터 삭제... -->
	<LABEL item="CS_Label" parent="CS_ConfirmDeleteChar">
		<BOUNDS>
			<X>19</X>
			<Y>30</Y>
			<W>260</W>
			<H>20</H>
		</BOUNDS>
		<TEXT>To delete a character, type 'YES' in the box and</TEXT>
	</LABEL>

	<!-- Label : 캐릭터 삭제... -->
	<LABEL item="CS_Label" parent="CS_ConfirmDeleteChar">
		<BOUNDS>
			<X>19</X>
			<Y>43</Y>
			<W>260</W>
			<H>20</H>
		</BOUNDS>
		<TEXT>press the OK button.</TEXT>
	</LABEL>

