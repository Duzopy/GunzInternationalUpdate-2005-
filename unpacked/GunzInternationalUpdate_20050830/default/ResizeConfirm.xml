<?xml version="1.0"?>
<XML ID="ResizeConfirm">
	<Schema xmlns="MaietData" xmlns:dt="MaietDataTypes"/>
	
	<!-- 해상도 변경하기전에 경고 메시지 출력하는 메시지 창 -->
	<FRAME item="ResizeConfirm">
		<FRAMELOOK>DefaultFrameLook</FRAMELOOK>
		<BOUNDS>
			<X>0</X>
			<Y>0</Y>
			<W>320</W>
			<H>187</H>
		</BOUNDS>
		<ALIGN>
			<HALIGN>center</HALIGN>
			<VALIGN>center</VALIGN>
		</ALIGN>
		<RESIZABLE>false</RESIZABLE>
		<VISIBLE>false</VISIBLE>
		<TEXT>Change Resolution</TEXT>
	</FRAME>
	
	<LABEL item="Label" parent="ResizeConfirm">
		<FONT>FONTa9</FONT>
		<TEXTCOLOR>
			<R>205</R>
			<G>205</G>
			<B>205</B>
		</TEXTCOLOR>
		<BOUNDS>
			<X>19</X>
			<Y>46</Y>
			<W>282</W>
			<H>20</H>
		</BOUNDS>
		<TEXT>Apply New Resolution.</TEXT>
	</LABEL>
	<LABEL item="Label" parent="ResizeConfirm">
		<FONT>FONTa9</FONT>
		<TEXTCOLOR>
			<R>205</R>
			<G>205</G>
			<B>205</B>
		</TEXTCOLOR>
		<BOUNDS>
			<X>19</X>
			<Y>66</Y>
			<W>282</W>
			<H>20</H>
		</BOUNDS>
		<TEXT>If a new resolution is not applied for 10 seconds,</TEXT>
	</LABEL>
	<LABEL item="Label" parent="ResizeConfirm">
		<FONT>FONTa9</FONT>
		<TEXTCOLOR>
			<R>205</R>
			<G>205</G>
			<B>205</B>
		</TEXTCOLOR>
		<BOUNDS>
			<X>19</X>
			<Y>78</Y>
			<W>282</W>
			<H>20</H>
		</BOUNDS>
		<TEXT>it returns to the previous resolution.</TEXT>
	</LABEL>
	<LABEL item="Label" parent="ResizeConfirm">
		<FONT>FONTa9</FONT>
		<TEXTCOLOR>
			<R>205</R>
			<G>205</G>
			<B>205</B>
		</TEXTCOLOR>
		<BOUNDS>
			<X>19</X>
			<Y>90</Y>
			<W>282</W>
			<H>20</H>
		</BOUNDS>
		<TEXT>Do you want to apply the new resolution?</TEXT>
	</LABEL>

	
	<BUTTON item="ResizeRequest" parent="ResizeConfirm">
		<BUTTONLOOK>DefaultButtonLook</BUTTONLOOK>
		<ANCHORS>
			<LEFT>true</LEFT>
			<TOP>true</TOP>
			<RIGHT>true</RIGHT>
			<BOTTOM>true</BOTTOM>
		</ANCHORS>
		<BOUNDS>
			<X>96</X>
			<Y>136</Y>
			<W>100</W>
			<H>32</H>
		</BOUNDS>
		<DEFAULTKEY>ENTER</DEFAULTKEY>
		<TEXT>OK(&amp;O)</TEXT>
	</BUTTON>
	<BUTTON item="ResizeCancel" parent="ResizeConfirm">
		<BUTTONLOOK>DefaultButtonLook</BUTTONLOOK>
		<ANCHORS>
			<LEFT>true</LEFT>
			<TOP>true</TOP>
			<RIGHT>true</RIGHT>
			<BOTTOM>true</BOTTOM>
		</ANCHORS>
		<BOUNDS>
			<X>201</X>
			<Y>136</Y>
			<W>100</W>
			<H>32</H>
		</BOUNDS>
		<DEFAULTKEY>ESC</DEFAULTKEY>
		<TEXT>Cancel(&amp;C)</TEXT>
	</BUTTON>
	
	<!-- 해상도 변경한 후 보이는지 다시 한번 묻는 창 -->

	<FRAME item="ViewConfirm">
		<FRAMELOOK>DefaultFrameLook</FRAMELOOK>
		<BOUNDS>
			<X>0</X>
			<Y>0</Y>
			<W>320</W>
			<H>187</H>
		</BOUNDS>
		<ALIGN>
			<HALIGN>center</HALIGN>
			<VALIGN>center</VALIGN>
		</ALIGN>
		<RESIZABLE>false</RESIZABLE>
		<VISIBLE>false</VISIBLE>
		<TEXT></TEXT>
	</FRAME>
	
	<LABEL item="Label" parent="ViewConfirm">
		<FONT>FONTa9</FONT>
		<TEXTCOLOR>
			<R>205</R>
			<G>205</G>
			<B>205</B>
		</TEXTCOLOR>
		<BOUNDS>
			<X>19</X>
			<Y>46</Y>
			<W>282</W>
			<H>20</H>
		</BOUNDS>
		<TEXT>New resolution has been applied.</TEXT>
	</LABEL>
	<LABEL item="Label" parent="ViewConfirm">
		<FONT>FONTa9</FONT>
		<TEXTCOLOR>
			<R>205</R>
			<G>205</G>
			<B>205</B>
		</TEXTCOLOR>
		<BOUNDS>
			<X>19</X>
			<Y>66</Y>
			<W>282</W>
			<H>20</H>
		</BOUNDS>
		<TEXT>Would you like to apply this resolution?</TEXT>
	</LABEL>
	
	<LABEL item="ViewConfirm_CountDown" parent="ViewConfirm">
		<BOUNDS>
			<X>19</X>
			<Y>96</Y>
			<W>282</W>
			<H>30</H>
		</BOUNDS>
		<ANCHORS>
			<LEFT>true</LEFT>
			<TOP>true</TOP>
			<RIGHT>true</RIGHT>
			<BOTTOM>true</BOTTOM>
		</ANCHORS>
		<TEXT></TEXT>
	</LABEL>
	
	<BUTTON item="ResizeAccept" parent="ViewConfirm">
		<BUTTONLOOK>DefaultButtonLook</BUTTONLOOK>
		<ANCHORS>
			<LEFT>true</LEFT>
			<TOP>true</TOP>
			<RIGHT>true</RIGHT>
			<BOTTOM>true</BOTTOM>
		</ANCHORS>
		<BOUNDS>
			<X>96</X>
			<Y>136</Y>
			<W>100</W>
			<H>32</H>
		</BOUNDS>
		<TEXT>Yes(&amp;Y)</TEXT>
	</BUTTON>
	<BUTTON item="ResizeReject" parent="ViewConfirm">
		<BUTTONLOOK>DefaultButtonLook</BUTTONLOOK>
		<ANCHORS>
			<LEFT>true</LEFT>
			<TOP>true</TOP>
			<RIGHT>true</RIGHT>
			<BOTTOM>true</BOTTOM>
		</ANCHORS>
		<BOUNDS>
			<X>201</X>
			<Y>136</Y>
			<W>100</W>
			<H>32</H>
		</BOUNDS>
		<DEFAULTKEY>ESC</DEFAULTKEY>
		<TEXT>No(&amp;N)</TEXT>
	</BUTTON>
	
</XML>